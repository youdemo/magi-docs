{
  "name": "magi",
  "displayName": "Magi",
  "description": "多智能体工程编排 system — 意图分析、任务拆解、异构专家协作",
  "version": "1.0.0",
  "icon": "resources/magi-icon.png",
  "license": "GPL-3.0-or-later",
  "author": "MistRipple",
  "publisher": "MistRipple",
  "repository": {
    "type": "git",
    "url": "https://github.com/MistRipple/magi"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "magi",
    "multi-agent",
    "orchestration",
    "claude",
    "gemini"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "magi.startTask",
        "title": "Magi: 启动任务"
      },
      {
        "command": "magi.checkCLIs",
        "title": "Magi: 检测 CLI 状态"
      },
      {
        "command": "magi.showPanel",
        "title": "Magi: 显示控制面板"
      },
      {
        "command": "magi.openPanel",
        "title": "Magi: 打开控制面板"
      },
      {
        "command": "magi.newSession",
        "title": "Magi: 新建会话"
      },
      {
        "command": "magi.showStatus",
        "title": "Magi: 显示 CLI 状态"
      },
      {
        "command": "magi.stopTask",
        "title": "Magi: 停止当前任务"
      },
      {
        "command": "magi.interruptTask",
        "title": "Magi: 打断当前任务"
      },
      {
        "command": "magi.testClaudePty",
        "title": "Magi: 测试 Claude PTY 初始化"
      },
      {
        "command": "magi.testTerminal",
        "title": "Magi: 测试 VSCode 终端"
      }
    ],
    "keybindings": [
      {
        "command": "magi.showPanel",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "magi.startTask",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "view == magi.mainView"
      },
      {
        "command": "magi.newSession",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "view == magi.mainView"
      },
      {
        "command": "magi.stopTask",
        "key": "ctrl+shift+backspace",
        "mac": "cmd+shift+backspace",
        "when": "magiTaskRunning"
      },
      {
        "command": "magi.interruptTask",
        "key": "escape",
        "when": "magiTaskRunning"
      }
    ],
    "configuration": {
      "title": "Magi",
      "properties": {
        "magi.claude.path": {
          "type": "string",
          "default": "claude",
          "description": "Claude CLI 可执行文件路径"
        },
        "magi.codex.path": {
          "type": "string",
          "default": "codex",
          "description": "Codex CLI 可执行文件路径"
        },
        "magi.gemini.path": {
          "type": "string",
          "default": "gemini",
          "description": "Gemini CLI 可执行文件路径"
        },
        "magi.defaultMode": {
          "type": "string",
          "enum": [
            "auto",
            "parallel",
            "sequential"
          ],
          "default": "auto",
          "description": "默认执行模式"
        },
        "magi.timeout": {
          "type": "number",
          "default": 300000,
          "description": "CLI 最大执行超时时间（毫秒）"
        },
        "magi.idleTimeout": {
          "type": "number",
          "default": 120000,
          "description": "CLI 空闲超时时间（毫秒，持续无输出才触发）"
        },
        "magi.maxTimeout": {
          "type": "number",
          "default": 900000,
          "description": "CLI 最大执行超时时间（毫秒）"
        },
        "magi.autoSnapshot": {
          "type": "boolean",
          "default": true,
          "description": "执行任务前自动创建文件快照"
        },
        "magi.permissions": {
          "type": "object",
          "default": {
            "allowEdit": true,
            "allowBash": true,
            "allowWeb": true
          },
          "description": "权限矩阵（编辑/命令/网络）",
          "properties": {
            "allowEdit": {
              "type": "boolean",
              "default": true
            },
            "allowBash": {
              "type": "boolean",
              "default": true
            },
            "allowWeb": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "magi.strategy": {
          "type": "object",
          "default": {
            "enableVerification": true,
            "enableRecovery": true,
            "autoRollbackOnFailure": false
          },
          "description": "执行策略开关",
          "properties": {
            "enableVerification": {
              "type": "boolean",
              "default": true
            },
            "enableRecovery": {
              "type": "boolean",
              "default": true
            },
            "autoRollbackOnFailure": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "magi.deepTask": {
          "type": "boolean",
          "default": false,
          "description": "深度任务模式（项目级治理）：提高编排/执行循环上限并启用多轮复审，适用于跨模块、多阶段、从 0 到 1 的复杂任务；关闭时为常规模式（功能级治理）。开启后仍保留空转检测、失败计数等安全网。新开会话后生效。"
        },
        "magi.cliSelection": {
          "type": "object",
          "default": {
            "enabled": true,
            "healthThreshold": 0.7
          },
          "description": "CLI 选择策略",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "healthThreshold": {
              "type": "number",
              "default": 0.7
            }
          }
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "magi",
          "title": "Magi",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "magi": [
        {
          "type": "webview",
          "id": "magi.mainView",
          "name": "Magi"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:extension && npm run build:webview",
    "compile": "tsc -p ./",
    "build:extension": "node esbuild.mjs --production",
    "watch": "tsc -watch -p ./",
    "watch:extension": "node esbuild.mjs --watch",
    "build:webview": "cd src/ui/webview-svelte && npm run build",
    "watch:webview": "cd src/ui/webview-svelte && npm run dev",
    "lint": "eslint src --ext ts",
    "verify:e2e:real-dispatch": "node scripts/e2e-real-dispatch-regression.cjs",
    "verify:e2e:real-dispatch:feature": "MAGI_E2E_DEEP_TASK=0 node scripts/e2e-real-dispatch-regression.cjs",
    "verify:e2e:real-dispatch:project": "MAGI_E2E_DEEP_TASK=1 node scripts/e2e-real-dispatch-regression.cjs",
    "verify:e2e:real-dispatch:compare": "npm run -s verify:e2e:real-dispatch:feature && npm run -s verify:e2e:real-dispatch:project",
    "verify:e2e:codebase-retrieval": "node scripts/e2e-codebase-retrieval-regression.cjs",
    "verify:e2e:index-stability": "node scripts/e2e-index-stability-regression.cjs",
    "verify:e2e:knowledge-learning": "node scripts/e2e-knowledge-learning-regression.cjs",
    "verify:e2e:model-error-governance": "node scripts/e2e-model-error-governance.cjs",
    "verify:e2e:model-error-matrix": "node scripts/e2e-model-error-scenario-matrix.cjs",
    "verify:e2e:session-isolation": "node scripts/e2e-session-isolation-regression.cjs",
    "verify:e2e:mode-governance": "node scripts/e2e-mode-governance-regression.cjs",
    "verify:e2e:plan-ledger-lifecycle": "node scripts/e2e-plan-ledger-lifecycle.cjs",
    "verify:e2e:plan-ledger-session-isolation": "node scripts/e2e-plan-ledger-session-isolation.cjs",
    "verify:e2e:plan-ledger-reconcile": "node scripts/e2e-plan-ledger-reconcile.cjs",
    "verify:e2e:plan-ledger-events-rotate": "node scripts/e2e-plan-ledger-events-rotate.cjs"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "diff": "^5.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "morphdom": "^2.7.8",
    "openai": "^6.16.0",
    "uuid": "^13.0.0"
  }
}
